<name>sys_script_include_5323f45553e7325005b475e0a0490ecb</name>
<payload>&lt;?xml version="1.0" encoding="UTF-8"?&gt;&lt;record_update table="sys_script_include"&gt;&lt;sys_script_include action="INSERT_OR_UPDATE"&gt;&lt;access&gt;package_private&lt;/access&gt;&lt;active&gt;true&lt;/active&gt;&lt;api_name&gt;global.TemperatureValidator&lt;/api_name&gt;&lt;caller_access/&gt;&lt;client_callable&gt;false&lt;/client_callable&gt;&lt;description/&gt;&lt;mobile_callable&gt;false&lt;/mobile_callable&gt;&lt;name&gt;TemperatureValidator&lt;/name&gt;&lt;sandbox_callable&gt;false&lt;/sandbox_callable&gt;&lt;script&gt;&lt;![CDATA[var TemperatureValidator = Class.create();
TemperatureValidator.prototype = {

    initialize: function() {},

    validateTemperature: function(value, fromUnit, toUnit, reportedValue) {

        gs.info("TEMP VALIDATOR START");
        gs.info("TEMP DEBUG input value: " + value);
        gs.info("TEMP DEBUG input unit: " + fromUnit);
        gs.info("TEMP DEBUG target unit: " + toUnit);
        gs.info("TEMP DEBUG reported value: " + reportedValue);

        // Validate numeric inputs
        if (isNaN(value) || isNaN(reportedValue)) {
            gs.info("TEMP DEBUG invalid numeric input");
            return "invalid";
        }

        // Map units to UCUM codes
        var fromUCUM = this.getUCUMUnit(fromUnit);
        var toUCUM = this.getUCUMUnit(toUnit);

        gs.info("TEMP DEBUG mapped fromUCUM: " + fromUCUM);
        gs.info("TEMP DEBUG mapped toUCUM: " + toUCUM);

        if (!fromUCUM || !toUCUM) {
            gs.info("TEMP DEBUG unit mapping failed");
            return "invalid";
        }

        // Convert temperature using UCUM service
        var converter = new UCUMConverter();
        var converted = converter.convertTemperature(Number(value), fromUCUM, toUCUM);

        gs.info("TEMP DEBUG converted value from UCUM: " + converted);

        if (converted === null) {
            gs.info("TEMP DEBUG conversion returned null");
            return "invalid";
        }

        // Determine significant figures
        var sigFigs = this.getSignificantFigures(value);
        gs.info("TEMP DEBUG significant figures: " + sigFigs);

        // Round values
        var roundedConverted = this.roundToSigFigs(Number(converted), sigFigs);
        var roundedReported = this.roundToSigFigs(Number(reportedValue), sigFigs);

        gs.info("TEMP DEBUG rounded converted: " + roundedConverted);
        gs.info("TEMP DEBUG rounded reported: " + roundedReported);

        // Compare values
        if (roundedConverted === roundedReported) {
            gs.info("TEMP DEBUG result: correct");
            return "correct";
        }

        gs.info("TEMP DEBUG result: incorrect");
        return "incorrect";
    },


    getUCUMUnit: function(unit) {

        if (!unit)
            return null;

        var normalized = String(unit).trim().toLowerCase();

        var units = {
            "fahrenheit": "%5BdegF%5D",
            "celsius": "Cel",
            "kelvin": "K",
            "rankine": "%5BdegR%5D",
            "rankin": "%5BdegR%5D"
        };

        return units[normalized] || null;
    },


    getSignificantFigures: function(value) {

        var str = String(value).trim();
        var hasDecimal = str.indexOf(".") !== -1;

        // Remove leading zeros (but keep "0.xxx")
        while (str.length &gt; 1 &amp;&amp; str.charAt(0) === "0" &amp;&amp; str.charAt(1) !== ".") {
            str = str.substring(1);
        }

        // Remove decimal for counting
        str = str.split(".").join("");

        // Strip trailing zeros ONLY if integer
        if (!hasDecimal) {
            while (str.length &gt; 1 &amp;&amp; str.endsWith("0")) {
                str = str.substring(0, str.length - 1);
            }
        }

        // Remove remaining leading zeros
        while (str.length &gt; 1 &amp;&amp; str.charAt(0) === "0") {
            str = str.substring(1);
        }

        return str.length;
    },


    roundToSigFigs: function(num, sigFigs) {

        var n = Number(num);

        if (n === 0)
            return 0;

        var multiplier = Math.pow(
            10,
            sigFigs - Math.floor(Math.log10(Math.abs(n))) - 1
        );

        return Math.round(n * multiplier) / multiplier;
    },


    type: 'TemperatureValidator'
};]]&gt;&lt;/script&gt;&lt;sys_class_name&gt;sys_script_include&lt;/sys_class_name&gt;&lt;sys_created_by&gt;admin&lt;/sys_created_by&gt;&lt;sys_created_on&gt;2026-03-09 17:38:11&lt;/sys_created_on&gt;&lt;sys_id&gt;5323f45553e7325005b475e0a0490ecb&lt;/sys_id&gt;&lt;sys_mod_count&gt;9&lt;/sys_mod_count&gt;&lt;sys_name&gt;TemperatureValidator&lt;/sys_name&gt;&lt;sys_package display_value="Global" source="global"&gt;global&lt;/sys_package&gt;&lt;sys_policy/&gt;&lt;sys_scope display_value="Global"&gt;global&lt;/sys_scope&gt;&lt;sys_update_name&gt;sys_script_include_5323f45553e7325005b475e0a0490ecb&lt;/sys_update_name&gt;&lt;sys_updated_by&gt;admin&lt;/sys_updated_by&gt;&lt;sys_updated_on&gt;2026-03-12 18:58:17&lt;/sys_updated_on&gt;&lt;/sys_script_include&gt;&lt;sys_es_latest_script action="INSERT_OR_UPDATE"&gt;&lt;id&gt;5323f45553e7325005b475e0a0490ecb&lt;/id&gt;&lt;sys_created_by&gt;admin&lt;/sys_created_by&gt;&lt;sys_created_on&gt;2026-03-09 17:38:11&lt;/sys_created_on&gt;&lt;sys_id&gt;c273385553e7325005b475e0a0490e53&lt;/sys_id&gt;&lt;sys_mod_count&gt;0&lt;/sys_mod_count&gt;&lt;sys_updated_by&gt;admin&lt;/sys_updated_by&gt;&lt;sys_updated_on&gt;2026-03-09 17:38:11&lt;/sys_updated_on&gt;&lt;table&gt;sys_script_include&lt;/table&gt;&lt;use_es_latest&gt;true&lt;/use_es_latest&gt;&lt;/sys_es_latest_script&gt;&lt;/record_update&gt;</payload>
