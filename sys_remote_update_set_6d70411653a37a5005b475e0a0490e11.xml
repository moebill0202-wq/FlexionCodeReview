<payload>&lt;?xml version="1.0" encoding="UTF-8"?&gt;&lt;record_update table="sys_script_include"&gt;&lt;sys_script_include action="INSERT_OR_UPDATE"&gt;&lt;access&gt;public&lt;/access&gt;&lt;active&gt;true&lt;/active&gt;&lt;api_name&gt;global.TemperatureValidatorAjax&lt;/api_name&gt;&lt;caller_access/&gt;&lt;client_callable&gt;true&lt;/client_callable&gt;&lt;description/&gt;&lt;mobile_callable&gt;false&lt;/mobile_callable&gt;&lt;name&gt;TemperatureValidatorAjax&lt;/name&gt;&lt;sandbox_callable&gt;false&lt;/sandbox_callable&gt;&lt;script&gt;&lt;![CDATA[var TemperatureValidatorAjax = Class.create();
TemperatureValidatorAjax.prototype = Object.extendsObject(global.AbstractAjaxProcessor, {

    validate: function() {
        try {
            var value = this.getParameter('sysparm_value');
            var fromUnit = this.getParameter('sysparm_from');
            var toUnit = this.getParameter('sysparm_to');
            var reported = this.getParameter('sysparm_reported');

            var validator = new TemperatureValidator();

            var result = validator.validateTemperature(
                value,
                fromUnit,
                toUnit,
                reported
            );

            return String(result);
        } catch (ex) {
            gs.error('TemperatureValidatorAjax error: ' + ex.message);
            return 'ERROR: ' + ex.message;
        }
    },

    type: 'TemperatureValidatorAjax'
});]]&gt;&lt;/script&gt;&lt;sys_class_name&gt;sys_script_include&lt;/sys_class_name&gt;&lt;sys_created_by&gt;admin&lt;/sys_created_by&gt;&lt;sys_created_on&gt;2026-03-09 19:17:20&lt;/sys_created_on&gt;&lt;sys_id&gt;5c79415553ab325005b475e0a0490e0d&lt;/sys_id&gt;&lt;sys_mod_count&gt;8&lt;/sys_mod_count&gt;&lt;sys_name&gt;TemperatureValidatorAjax&lt;/sys_name&gt;&lt;sys_package display_value="Global" source="global"&gt;global&lt;/sys_package&gt;&lt;sys_policy/&gt;&lt;sys_scope display_value="Global"&gt;global&lt;/sys_scope&gt;&lt;sys_update_name&gt;sys_script_include_5c79415553ab325005b475e0a0490e0d&lt;/sys_update_name&gt;&lt;sys_updated_by&gt;admin&lt;/sys_updated_by&gt;&lt;sys_updated_on&gt;2026-03-10 11:14:02&lt;/sys_updated_on&gt;&lt;/sys_script_include&gt;&lt;sys_es_latest_script action="INSERT_OR_UPDATE"&gt;&lt;id&gt;5c79415553ab325005b475e0a0490e0d&lt;/id&gt;&lt;sys_created_by&gt;admin&lt;/sys_created_by&gt;&lt;sys_created_on&gt;2026-03-09 19:17:19&lt;/sys_created_on&gt;&lt;sys_id&gt;1a2ac19553ab325005b475e0a0490ef8&lt;/sys_id&gt;&lt;sys_mod_count&gt;0&lt;/sys_mod_count&gt;&lt;sys_updated_by&gt;admin&lt;/sys_updated_by&gt;&lt;sys_updated_on&gt;2026-03-09 19:17:19&lt;/sys_updated_on&gt;&lt;table&gt;sys_script_include&lt;/table&gt;&lt;use_es_latest&gt;true&lt;/use_es_latest&gt;&lt;/sys_es_latest_script&gt;&lt;/record_update&gt;</payload>
