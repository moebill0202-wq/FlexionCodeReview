<name>sys_ui_page_a5a7cd1153ab325005b475e0a0490eb9</name>
<payload>&lt;?xml version="1.0" encoding="UTF-8"?&gt;&lt;record_update table="sys_ui_page"&gt;&lt;sys_ui_page action="INSERT_OR_UPDATE"&gt;&lt;category&gt;general&lt;/category&gt;&lt;client_script&gt;&lt;![CDATA[function validateTemperature() {

    var value = document.getElementById("inputValue").value.trim();
    var fromUnit = document.getElementById("inputUnit").value;
    var toUnit = document.getElementById("targetUnit").value;
    var reported = document.getElementById("reportedValue").value.trim();
    var resultEl = document.getElementById("result");

    // Basic check for empty fields
    if (!value || !reported) {
        resultEl.className = "temp-result error";
        resultEl.textContent = "Please enter both input value and reported reading.";
        return;
    }

    var ga = new GlideAjax('TemperatureValidatorAjax');

    ga.addParam('sysparm_name', 'validate');
    ga.addParam('sysparm_value', value);
    ga.addParam('sysparm_from', fromUnit);
    ga.addParam('sysparm_to', toUnit);
    ga.addParam('sysparm_reported', reported);

    ga.getXMLAnswer(function(answer) {

        var response = String(answer).toLowerCase().trim();

        resultEl.className = "temp-result " + response;
        resultEl.textContent = response.charAt(0).toUpperCase() + response.slice(1);
    });

}]]&gt;&lt;/client_script&gt;&lt;description/&gt;&lt;direct&gt;false&lt;/direct&gt;&lt;endpoint/&gt;&lt;html&gt;&lt;![CDATA[&lt;?xml version="1.0" encoding="utf-8" ?&gt;
&lt;j:jelly trim="false" xmlns:j="jelly:core" xmlns:g="glide"&gt;

&lt;html lang="en"&gt;

&lt;head&gt;
&lt;meta charset="utf-8"/&gt;
&lt;title&gt;Temperature Validation&lt;/title&gt;

&lt;style&gt;
body {
    margin: 0;
    padding: 30px 20px;
    background: #f5f5f5;
}

.temp-form {
    max-width: 450px;
    margin: 20px auto;
    font-family: SourceSansPro, Arial, sans-serif;
}

.temp-form h2 {
    margin-bottom: 16px;
}

.temp-form table {
    width: 100%;
    border-spacing: 0 10px;
}

.temp-form td.label {
    width: 140px;
    font-weight: bold;
    padding-right: 10px;
    vertical-align: middle;
}

.temp-form input[type="text"],
.temp-form select {
    width: 100%;
    padding: 6px 8px;
    font-size: 14px;
    border: 1px solid #bbb;
    border-radius: 3px;
}

.temp-form input[type="text"]:focus,
.temp-form select:focus {
    outline: none;
    border-color: #4a90d9;
}

.temp-form .btn-validate {
    padding: 8px 20px;
    font-size: 14px;
    background: #4a90d9;
    color: #fff;
    border: none;
    border-radius: 3px;
    cursor: pointer;
}

.temp-form .btn-validate:hover {
    background: #3a7bc8;
}

.temp-result {
    margin-top: 12px;
    padding: 8px 12px;
    font-weight: bold;
    display: none;
    border-radius: 3px;
}

.temp-result.correct {
    display: block;
    background: #dff0d8;
    color: #3c763d;
    border: 1px solid #d6e9c6;
}

.temp-result.incorrect {
    display: block;
    background: #f2dede;
    color: #a94442;
    border: 1px solid #ebccd1;
}

.temp-result.invalid {
    display: block;
    background: #fcf8e3;
    color: #8a6d3b;
    border: 1px solid #faebcc;
}

.temp-result.error {
    display: block;
    background: #f2dede;
    color: #a94442;
    border: 1px solid #ebccd1;
}
&lt;/style&gt;

&lt;/head&gt;

&lt;body&gt;

&lt;div class="temp-form"&gt;

&lt;h2&gt;Temperature Validation&lt;/h2&gt;

&lt;table&gt;

&lt;tr&gt;
&lt;td class="label"&gt;Input Value:&lt;/td&gt;
&lt;td&gt;
&lt;input id="inputValue" type="text" placeholder="e.g. 84.2"/&gt;
&lt;/td&gt;
&lt;/tr&gt;

&lt;tr&gt;
&lt;td class="label"&gt;Input Unit:&lt;/td&gt;
&lt;td&gt;
&lt;select id="inputUnit"&gt;
&lt;option&gt;Fahrenheit&lt;/option&gt;
&lt;option&gt;Celsius&lt;/option&gt;
&lt;option&gt;Kelvin&lt;/option&gt;
&lt;option&gt;Rankine&lt;/option&gt;
&lt;/select&gt;
&lt;/td&gt;
&lt;/tr&gt;

&lt;tr&gt;
&lt;td class="label"&gt;Target Unit:&lt;/td&gt;
&lt;td&gt;
&lt;select id="targetUnit"&gt;
&lt;option&gt;Fahrenheit&lt;/option&gt;
&lt;option&gt;Celsius&lt;/option&gt;
&lt;option&gt;Kelvin&lt;/option&gt;
&lt;option&gt;Rankine&lt;/option&gt;
&lt;/select&gt;
&lt;/td&gt;
&lt;/tr&gt;

&lt;tr&gt;
&lt;td class="label"&gt;Reported Reading:&lt;/td&gt;
&lt;td&gt;
&lt;input id="reportedValue" type="text" placeholder="e.g. 29.0"/&gt;
&lt;/td&gt;
&lt;/tr&gt;

&lt;tr&gt;
&lt;td colspan="2"&gt;
&lt;button class="btn-validate" onclick="validateTemperature()"&gt;Validate&lt;/button&gt;
&lt;/td&gt;
&lt;/tr&gt;

&lt;/table&gt;

&lt;div class="temp-result" id="result"&gt;&lt;/div&gt;

&lt;/div&gt;

&lt;/body&gt;
